{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug HTTP Server",
            "program": "${workspaceFolder}/Day 1/server.js", // <-- points to your exact file path
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "integratedTerminal", // Shows server logs in VS Code terminal
            "stopOnEntry": false, // Don't auto-pause at first line
            "outputCapture": "std"
        }
    ]
}